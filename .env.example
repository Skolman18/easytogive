# EasyToGive — copy to .env.local and fill in values.
# For staging/local: use a separate Supabase project and Stripe test keys.

# Supabase (create a staging project at supabase.com for non-production)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Groq (for org autofill)
GROQ_API_KEY=gsk_...

# Stripe — use test keys for staging/local (pk_test_..., sk_test_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_... or pk_live_...
STRIPE_SECRET_KEY=sk_test_... or sk_live_...

# Optional: set to "staging" only in your Vercel staging project to show the staging banner
# NEXT_PUBLIC_APP_ENV=staging
